<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
			 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			 xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

	<persistence-unit name="seriesPU">
		<jta-data-source>java:/labsDS</jta-data-source>
		<class>ch.hevs.businessobject.Account</class>
		<class>ch.hevs.businessobject.Viewer</class>
		<class>ch.hevs.businessobject.Administrator</class>
		<class>ch.hevs.businessobject.Series</class>
		<class>ch.hevs.businessobject.Season</class>
		<class>ch.hevs.businessobject.Episode</class>
		<class>ch.hevs.businessobject.Review</class>
		<class>ch.hevs.businessobject.SeriesProgress</class>
		<class>ch.hevs.businessobject.SeasonProgress</class>
		<class>ch.hevs.businessobject.EpisodeProgress</class>
		<properties>
			<property name="hibernate.cache.use_second_level_cache" value="true" />
			<property name="hibernate.cache.use_query_cache" value="true" />
			<property name="hibernate.format_sql" value="true"/>
			<property name="hibernate.jpa.compliance.query" value="false"/>
			<property name="jakarta.persistence.schema-generation.database.action" value="none"/>
			<property name="hibernate.physical_naming_strategy" value="org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl"/>
		</properties>
	</persistence-unit>

</persistence>
